{
  "profiles": [
    {
      "name": "Tech-Enhanced Market Opportunities",
      "company_profile": "Provision Systems & Provisions Unlimited: SDVOSB partnership that leverages technology and AI to create competitive advantages across industries. We specialize in using IT solutions, data analytics, automation, and process optimization to dominate markets where traditional competitors rely on manual processes. Core capabilities include: software development, database management, system integration, AI/ML applications, process automation, compliance management systems, vendor management platforms, supply chain optimization, and digital transformation. We excel at identifying inefficient manual processes and building technology solutions that scale. Located in Northeast corridor with nationwide delivery capability. Our competitive advantage: we bring Silicon Valley tech innovation to traditional government contracting sectors.",
      "sam": {
        "api_key_env": "SAM_API_KEY",
        "base_url": "https://api.sam.gov",
        "posted_lookback_days": 0,
        "limit": 50,
        "fetch_descriptions": true,
        "description_max_chars": 16000,
        "max_descriptions_per_run": 10,
        "max_pages_per_run": 2,
        "fetch_attachments": false,
        "filters": {
          "setAsideCodes": [
            "SDVOSBC",
            "SDVOSBS",
            "SBA",
            "SBP",
            "8A",
            "8AN"
          ],
          "minAmount": 25000,
          "maxAmount": 5000000
        }
      },
      "scoring": {
        "min_good_fit_score": 45,
        "min_maybe_score": 25,
        "ai_enabled": true,
        "ai_model": "gemini-pro-latest",
        "ai_timeout_seconds": 30,
        "positive_keywords": [
          "manual processes",
          "paperwork",
          "spreadsheets",
          "tracking",
          "coordination",
          "scheduling",
          "documentation",
          "compliance",
          "vendor management",
          "inventory",
          "quality assurance",
          "reporting",
          "data collection",
          "record keeping",
          "administrative",
          "logistics",
          "supply chain",
          "procurement",
          "monitoring",
          "oversight",
          "audit",
          "inspection",
          "certification",
          "standardization",
          "efficiency",
          "streamline",
          "modernization",
          "digitization",
          "automation",
          "system integration",
          "database",
          "software",
          "platform",
          "analytics",
          "artificial intelligence",
          "machine learning"
        ],
        "negative_keywords": [
          "top secret clearance required",
          "secret clearance required",
          "polygraph required",
          "relocation required",
          "on-site only",
          "heavy machinery operation",
          "hazardous materials handling",
          "medical procedures",
          "surgery",
          "pharmaceutical manufacturing",
          "food preparation",
          "childcare",
          "education instruction"
        ]
      },
      "slack": {
        "bot_token_env": "SLACK_BOT_TOKEN",
        "channel": "#sdvosb-it-opportunities",
