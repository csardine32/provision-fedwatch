{
  "sam": {
    "api_key_env": "SAM_API_KEY",
    "base_url": "https://api.sam.gov",
    "posted_lookback_days": 1,
    "limit": 100,
    "fetch_descriptions": true,
    "description_max_chars": 5000,
    "max_descriptions_per_run": 1,
    "max_pages_per_run": null,
    "filters": {}
  },
  "scoring": {
    "min_good_fit_score": 75,
    "min_maybe_score": 55,
    "ai_enabled": false,
    "ai_model": "gpt-5.1",
    "ai_timeout_seconds": 10
  },
  "slack": {
    "webhook_url_env": "SLACK_WEBHOOK_URL",
    "bot_token_env": "SLACK_BOT_TOKEN",
    "channel": "",
    "post_not_a_fit": false
  },
  "alerting": {
    "post_good_fit": true,
    "post_maybe": true
  },
  "storage": {
    "sqlite_path": "./.data/test-opportunity-bot-cap.sqlite"
  }
}
